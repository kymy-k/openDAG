{
  "name": "@themifaso/opendag",
  "version": "0.1.1",
  "description": "Contract-first functional DAG workflow and CLI for coding-agent work.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://github.com/kymy-k/openDAG#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kymy-k/openDAG.git"
  },
  "bugs": {
    "url": "https://github.com/kymy-k/openDAG/issues"
  },
  "keywords": [
    "codex",
    "dag",
    "functional-programming",
    "agents",
    "contracts",
    "zod",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/contractTypes.d.ts",
      "import": "./dist/contracts/contractTypes.js"
    }
  },
  "bin": {
    "opendag-create-node": "dist/tools/create-node.js",
    "opendag-generate-docs": "dist/tools/generate-node-docs.js",
    "opendag-install-skills": "dist/tools/install-skills.js",
    "opendag-validate-dag": "dist/tools/validate-dag.js",
    "opendag-verify-all": "dist/tools/verify-all.js",
    "opendag-verify-file-scope": "dist/tools/verify-file-scope.js",
    "opendag-verify-node": "dist/tools/verify-node.js",
    "opendag-visualise": "dist/tools/visualise.js"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "SETUP_GUIDE.md",
    "dist/",
    "opendag/",
    "specs/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "validate:dag": "tsx tools/validate-dag.ts",
    "verify:node": "tsx tools/verify-node.ts",
    "verify:all": "tsx tools/verify-all.ts",
    "verify:file-scope": "tsx tools/verify-file-scope.ts",
    "create:node": "tsx tools/create-node.ts",
    "generate:docs": "tsx tools/generate-node-docs.ts",
    "check:docs": "tsx tools/generate-node-docs.ts --check",
    "install:skills": "tsx tools/install-skills.ts",
    "visualise": "tsx tools/visualise.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify:all && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "fast-check": "^3.22.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.4"
  }
}
